{
  "name": "hoikuen-line-reminder-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "start": "tsx src/server/index.ts",
    "seed": "tsx src/server/seed.ts"
  },
  "dependencies": {
    "@line/bot-sdk": "7.5.2",
    "@vitejs/plugin-react": "4.2.1",
    "better-sqlite3": "9.6.0",
    "concurrently": "8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "node-cron": "^3.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsx": "3.14.0",
    "typescript": "5.4.5",
    "vite": "4.5.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "4.17.21",
    "@types/node": "20.11.30",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "3.4.3"
  }
}
